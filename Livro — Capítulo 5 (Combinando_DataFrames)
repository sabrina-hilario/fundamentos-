        "**2)** Depois de juntar todos os DataFrames em um único DataFrame, faça o seguinte:\n",
        "\n",
        "Mostre apenas a coluna regiao e faturamento;\n",
        "\n",
        "Calcule o faturamento total de cada região"
      ],
      "metadata": {
        "id": "N5_qPIYM2MRS"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import pandas as pd\n",
        "\n",
        "regiaoNorte = pd.DataFrame({\n",
        "    \"regiao\": [\"Norte\", \"Norte\", \"Norte\"],\n",
        "    \"dia\": [\"sex\", \"sab\", \"dom\"],\n",
        "    \"faturamento\": [6800, 7200, 8100]\n",
        "})\n",
        "\n",
        "regiaoSul = pd.DataFrame({\n",
        "    \"regiao\": [\"Sul\", \"Sul\", \"Sul\"],\n",
        "    \"dia\": [\"sex\", \"sab\", \"dom\"],\n",
        "    \"faturamento\": [5400, 6300, 7900]\n",
        "})\n",
        "\n",
        "regiaoLeste = pd.DataFrame({\n",
        "    \"regiao\": [\"Leste\", \"Leste\"],\n",
        "    \"dia\": [\"sex\", \"sab\"],\n",
        "    \"faturamento\": [950.50, 1200.75]\n",
        "})\n",
        "\n",
        "# Junta todos os DataFrames\n",
        "regioes = pd.concat([regiaoNorte, regiaoSul, regiaoLeste], ignore_index=True)\n",
        "\n",
        "# Soma do faturamento por região\n",
        "total_regiao = regioes.groupby(\"regiao\")[\"faturamento\"].sum()\n",
        "\n",
        "print(total_regiao)"
